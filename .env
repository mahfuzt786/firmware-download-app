# =============================================================================
# BimmerTech Firmware Download App - Environment Configuration
# =============================================================================
# In production, copy this file to .env.local and update the values.
# NEVER commit .env.local to version control.
# =============================================================================

# Application environment: dev, test, or prod
APP_ENV=dev

# Set this to a unique, random string of at least 32 characters in production
APP_SECRET=change_this_to_a_random_secret_string_in_production

# Database connection (SQLite by default - no external database server needed)
# For MySQL: DATABASE_URL="mysql://user:password@127.0.0.1:3306/firmware_db?serverVersion=8.0"
# For PostgreSQL: DATABASE_URL="postgresql://user:password@127.0.0.1:5432/firmware_db?serverVersion=15"
DATABASE_URL="sqlite:///%kernel.project_dir%/var/data.db"

