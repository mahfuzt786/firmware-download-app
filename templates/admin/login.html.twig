{# ==========================================================================
   Admin Login Page
   
   Modern, visually distinct login page for the BimmerTech admin panel.
   Uses a split-screen layout with a gradient sidebar and a clean form area.
   ========================================================================== #}
{% extends 'base.html.twig' %}

{% block title %}Admin Login - BimmerTech{% endblock %}

{% block stylesheets %}
<style>
    /* =====================================================================
       Login Page Styles — Modern Split-Screen Layout
       ===================================================================== */
    *, *::before, *::after {
        box-sizing: border-box;
    }

    html, body {
        height: 100%;
        margin: 0;
        padding: 0;
        overflow: hidden;
    }

    body {
        font-family: 'Rubik', sans-serif;
        background: #f0f2f5;
    }

    .login-wrapper {
        display: flex;
        min-height: 100vh;
    }

    /* --- Left panel: gradient brand area --- */
    .login-brand {
        flex: 0 0 45%;
        background: linear-gradient(135deg, #0f0c29 0%, #302b63 50%, #24243e 100%);
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        padding: 60px 40px;
        position: relative;
        overflow: hidden;
    }

    /* Subtle animated floating circles for depth */
    .login-brand::before,
    .login-brand::after {
        content: '';
        position: absolute;
        border-radius: 50%;
        opacity: 0.06;
        background: #fff;
    }

    .login-brand::before {
        width: 400px;
        height: 400px;
        top: -80px;
        left: -100px;
        animation: float 8s ease-in-out infinite;
    }

    .login-brand::after {
        width: 300px;
        height: 300px;
        bottom: -60px;
        right: -80px;
        animation: float 10s ease-in-out infinite reverse;
    }

    @keyframes float {
        0%, 100% { transform: translateY(0) rotate(0deg); }
        50%      { transform: translateY(-30px) rotate(5deg); }
    }

    .brand-content {
        position: relative;
        z-index: 1;
        text-align: center;
        color: #fff;
    }

    .brand-icon {
        width: 80px;
        height: 80px;
        background: rgba(255,255,255,0.1);
        border-radius: 20px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 28px;
        backdrop-filter: blur(10px);
        border: 1px solid rgba(255,255,255,0.15);
    }

    .brand-icon i {
        font-size: 36px;
        color: #a78bfa;
    }

    .brand-content h1 {
        font-size: 28px;
        font-weight: 700;
        margin: 0 0 12px;
        letter-spacing: -0.5px;
    }

    .brand-content p {
        font-size: 15px;
        color: rgba(255,255,255,0.6);
        line-height: 1.6;
        max-width: 320px;
        margin: 0 auto;
    }

    .brand-features {
        margin-top: 48px;
        display: flex;
        flex-direction: column;
        gap: 16px;
    }

    .brand-feature {
        display: flex;
        align-items: center;
        gap: 14px;
        color: rgba(255,255,255,0.7);
        font-size: 14px;
    }

    .brand-feature-icon {
        width: 36px;
        height: 36px;
        background: rgba(255,255,255,0.08);
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    .brand-feature-icon i {
        font-size: 16px;
        color: #a78bfa;
    }

    /* --- Right panel: login form area --- */
    .login-form-area {
        flex: 1;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 40px;
        background: #f8f9fb;
    }

    .login-card {
        width: 100%;
        max-width: 420px;
    }

    .login-card h2 {
        font-size: 26px;
        font-weight: 700;
        color: #1a1a2e;
        margin: 0 0 6px;
    }

    .login-card .subtitle {
        font-size: 14px;
        color: #6b7280;
        margin: 0 0 32px;
    }

    /* Error alert */
    .login-error {
        background: #fef2f2;
        border: 1px solid #fecaca;
        border-radius: 12px;
        padding: 14px 16px;
        margin-bottom: 24px;
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .login-error i {
        color: #ef4444;
        font-size: 20px;
        flex-shrink: 0;
    }

    .login-error span {
        font-size: 14px;
        color: #991b1b;
    }

    /* Form fields */
    .form-field {
        margin-bottom: 20px;
    }

    .form-field label {
        display: block;
        font-size: 13px;
        font-weight: 500;
        color: #374151;
        margin-bottom: 6px;
    }

    .input-wrapper {
        position: relative;
    }

    .input-wrapper > i {
        position: absolute;
        left: 14px;
        top: 50%;
        transform: translateY(-50%);
        font-size: 18px;
        color: #9ca3af;
        pointer-events: none;
        transition: color 0.2s;
    }

    .input-wrapper input {
        width: 100%;
        padding: 12px 14px 12px 44px;
        border: 1.5px solid #e5e7eb;
        border-radius: 12px;
        font-size: 15px;
        font-family: 'Rubik', sans-serif;
        background: #fff;
        color: #1f2937;
        outline: none;
        transition: border-color 0.2s, box-shadow 0.2s;
    }

    /* Keep room for the eye icon inside password input */
    #password {
        padding-right: 44px;
    }

    .input-wrapper input:focus {
        border-color: #6366f1;
        box-shadow: 0 0 0 3px rgba(99, 102, 241, 0.12);
    }

    .input-wrapper input:focus + i,
    .input-wrapper input:focus ~ i {
        color: #6366f1;
    }

    /* Password toggle */
    .toggle-password {
        position: absolute;
        right: 10px;
        top: 50%;
        transform: translateY(-50%);
        background: none;
        border: none;
        cursor: pointer;
        color: #9ca3af;
        font-size: 18px;
        padding: 4px;
        pointer-events: all;
        transition: color 0.2s;
        z-index: 2;
    }

    .toggle-password i {
        position: static;
        left: auto;
        top: auto;
        transform: none;
        pointer-events: none;
        color: currentColor;
    }

    .toggle-password:hover {
        color: #6366f1;
    }

    /* Submit button */
    .btn-login {
        width: 100%;
        padding: 13px;
        background: linear-gradient(135deg, #6366f1 0%, #4f46e5 100%);
        color: #fff;
        border: none;
        border-radius: 12px;
        font-size: 15px;
        font-weight: 600;
        font-family: 'Rubik', sans-serif;
        cursor: pointer;
        transition: transform 0.15s, box-shadow 0.2s;
        letter-spacing: 0.3px;
        margin-top: 8px;
    }

    .btn-login:hover {
        transform: translateY(-1px);
        box-shadow: 0 6px 20px rgba(99, 102, 241, 0.35);
    }

    .btn-login:active {
        transform: translateY(0);
        box-shadow: 0 2px 8px rgba(99, 102, 241, 0.25);
    }

    /* Back link */
    .back-link {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        margin-top: 24px;
        font-size: 13px;
        color: #6b7280;
        text-decoration: none;
        transition: color 0.2s;
    }

    .back-link:hover {
        color: #6366f1;
    }

    /* Footer */
    .login-footer {
        margin-top: 40px;
        font-size: 12px;
        color: #9ca3af;
        text-align: center;
    }

    /* ---- Responsive ---- */
    @media (max-width: 900px) {
        .login-brand {
            display: none;
        }
        .login-form-area {
            padding: 32px 20px;
        }
    }
</style>
{% endblock %}

{% block body %}
<div class="login-wrapper">
    {# =====================================================================
       Left Panel — Brand / Info
       ===================================================================== #}
    <div class="login-brand">
        <div class="brand-content">
            <div class="brand-icon">
                <i class="bi bi-shield-lock-fill"></i>
            </div>
            <h1>BimmerTech Admin</h1>
            <p>Firmware version management for CarPlay&nbsp;/&nbsp;Android&nbsp;Auto MMI products.</p>

            <div class="brand-features">
                <div class="brand-feature">
                    <div class="brand-feature-icon"><i class="bi bi-collection"></i></div>
                    <span>Manage software versions across all products</span>
                </div>
                <div class="brand-feature">
                    <div class="brand-feature-icon"><i class="bi bi-cloud-arrow-up"></i></div>
                    <span>Update download links for ST &amp; GD hardware</span>
                </div>
                <div class="brand-feature">
                    <div class="brand-feature-icon"><i class="bi bi-check2-circle"></i></div>
                    <span>Mark and manage latest firmware releases</span>
                </div>
            </div>
        </div>
    </div>

    {# =====================================================================
       Right Panel — Login Form
       ===================================================================== #}
    <div class="login-form-area">
        <div class="login-card">
            <h2>Welcome back</h2>
            <p class="subtitle">Sign in to access the admin dashboard.</p>

            {# Authentication error message #}
            {% if error %}
                <div class="login-error">
                    <i class="bi bi-exclamation-circle-fill"></i>
                    <span>{{ error.messageKey|trans(error.messageData, 'security') }}</span>
                </div>
            {% endif %}

            {# Login form — posts to the same route (admin_login) #}
            <form method="post" action="{{ path('admin_login') }}">
                {# CSRF token for security #}
                <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

                {# Username field #}
                <div class="form-field">
                    <label for="username">Username</label>
                    <div class="input-wrapper">
                        <input type="text"
                               id="username"
                               name="_username"
                               value="{{ last_username }}"
                               placeholder="Enter your username"
                               autocomplete="username"
                               autofocus
                               required>
                        <i class="bi bi-person"></i>
                    </div>
                </div>

                {# Password field with show/hide toggle #}
                <div class="form-field">
                    <label for="password">Password</label>
                    <div class="input-wrapper">
                        <input type="password"
                               id="password"
                               name="_password"
                               placeholder="Enter your password"
                               autocomplete="current-password"
                               required>
                        <i class="bi bi-lock"></i>
                        <button type="button"
                                class="toggle-password"
                                onclick="togglePassword()"
                                title="Show password">
                            <i class="bi bi-eye" id="toggleIcon"></i>
                        </button>
                    </div>
                </div>

                {# Submit button #}
                <button type="submit" class="btn-login">
                    Sign In
                </button>
            </form>

            {# Link back to public page #}
            <a href="{{ path('software_download') }}" class="back-link">
                <i class="bi bi-arrow-left"></i> Back to download page
            </a>

            <div class="login-footer">
                &copy; {{ 'now'|date('Y') }} BimmerTech. All rights reserved.
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
<script>
/**
 * Toggle password visibility in the login form.
 */
function togglePassword() {
    var input = document.getElementById('password');
    var icon = document.getElementById('toggleIcon');

    if (input.type === 'password') {
        input.type = 'text';
        icon.classList.remove('bi-eye');
        icon.classList.add('bi-eye-slash');
    } else {
        input.type = 'password';
        icon.classList.remove('bi-eye-slash');
        icon.classList.add('bi-eye');
    }
}
</script>
{% endblock %}
